# MTN Mobile Money API Configuration
# Get these credentials from: https://momodeveloper.mtn.com/
# For Sandbox testing:
# 1. Subscribe to "Sandbox User Provisioning" product to create API users
# 2. Subscribe to "Collections" product for payment processing
# 3. Generate API User and API Key using the sandbox provisioning API

# Set to 'true' to use mock service (no real MTN credentials needed)
# Set to 'false' to use real MTN API
# ─── MTN Mobile Money Configuration ─────────────────────────────────────────
#
# HOW TO GET REAL SANDBOX CREDENTIALS:
#
#  1. Go to https://momodeveloper.mtn.com and create an account
#  2. Subscribe to TWO products:
#       a) "Collection"  (payment processing)  → gives you a Subscription Key
#       b) "Sandbox User Provisioning"         → allows creating API users
#  3. Run the provisioning script ONCE to create your API user and key:
#         node scripts/provision-mtn-sandbox.js
#     It will print MTN_API_USER, MTN_CONSUMER_KEY and MTN_CONSUMER_SECRET.
#     Paste those values below.
#
#  Variable meanings:
#    MTN_CONSUMER_KEY    = Ocp-Apim-Subscription-Key from the Collection product
#    MTN_API_USER        = UUID created by the provisioning API (v4 UUID)
#    MTN_CONSUMER_SECRET = API Key generated for that UUID (kept secret)
#    MTN_ENV             = 'sandbox' for testing, 'production' for live
#
#  ⚠  The HDEV-… values below are placeholder format — replace with real values.
#     Until MTN_CONSUMER_SECRET is filled in the service auto-falls back to mock.
# ─────────────────────────────────────────────────────────────────────────────
# MTN_USE_MOCK=false
# MTN_CONSUMER_KEY=REPLACE_WITH_YOUR_OCP_APIM_SUBSCRIPTION_KEY
# MTN_CONSUMER_SECRET=HDEV-c0dd395e-e7c0-4e06-b6e2-25595b3827c5-KEY
# MTN_API_USER=79df19cc-3202-44d1-a56a-12c5c73faeaf
# MTN_ENV=sandbox
# PAYMENT_PRIMARY_KEY=5443b37a3dac47afb1668ff99405f30b
# PAYMENT_SECONDARY_KEY=c9c288ca34064d05995de4a6eccec9b8

# MTN Mobile Money Configuration

PAYMENT_PROVIDER=generic
PAYMENT_API_BASE_URL=https://payment.hdevtech.cloud/api_pay/api
PAYMENT_API_ID=HDEV-79df19cc-3202-44d1-a56a-12c5c73faeaf-ID
PAYMENT_API_KEY=HDEV-c0dd395e-e7c0-4e06-b6e2-25595b3827c5-KEY
PAYMENT_INITIATE_PATH=/initiate_payment
PAYMENT_STATUS_PATH=/payment_status

